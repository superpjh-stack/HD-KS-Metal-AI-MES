# Server
PORT=3001
NODE_ENV=development

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ks-mes
KEYCLOAK_CLIENT_ID=ks-mes-web
KEYCLOAK_CLIENT_SECRET=ks-mes-web-secret

# JWT (Access Token: 15m, Refresh Token: 8h)
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=28800

# Cookie
COOKIE_SECRET=change-me-in-production
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
