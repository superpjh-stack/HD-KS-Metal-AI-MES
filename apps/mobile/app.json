{
  "expo": {
    "name": "KS-MES Worker",
    "slug": "ks-mes-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ks-mes",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      ["expo-notifications", { "sounds": [] }]
    ],
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.ksmetal.mes" },
    "android": { "adaptiveIcon": { "backgroundColor": "#1d4ed8" }, "package": "com.ksmetal.mes" }
  }
}
